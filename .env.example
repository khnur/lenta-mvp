# ---------------------------------------------------------------------------
# lenta-mvp environment. Copy to `.env` for local dev (docker-compose reads it).
# NEVER commit a real .env. All services read config from the environment only.
# ---------------------------------------------------------------------------

# ---- Datastores -----------------------------------------------------------
# Local docker-compose uses the service hostnames `postgres` / `redis`.
# Railway injects DATABASE_URL / REDIS_URL automatically from the plugins.
DATABASE_URL=postgresql+psycopg://lenta:lenta@localhost:5432/lenta
REDIS_URL=redis://localhost:6379/0

# ---- Determinism (reproducible demos) -------------------------------------
LENTA_SEED=42

# ---- Mock data sizes ------------------------------------------------------
LENTA_N_VIDEOS=600
LENTA_N_USERS=400
LENTA_BACKFILL_DAYS=30
LENTA_BACKFILL_EVENTS=40000
LENTA_N_GENRES=12

# ---- Trainer --------------------------------------------------------------
SEED_ON_BOOT=true                 # on first boot, seed catalog/users/events + train v1
RETRAIN_INTERVAL_MINUTES=5        # nightly in prod; minutes for a live demo
TRAINER_POLL_SECONDS=3            # how often the trainer polls the jobs table
SIM_DEFAULT_RATE=6                # synthetic events/sec when the simulator runs

# ---- API ------------------------------------------------------------------
API_HOST=0.0.0.0
PORT=8000                          # Railway/compose set this; binds $PORT
API_URL=http://localhost:8000      # trainer + simulator POST events here
MODEL_RELOAD_SECONDS=5             # api polls the registry for a newer active model
ALS_CANDIDATES=300                 # retrieval shortlist size
LOG_LEVEL=INFO

# ---- Dashboard (build-time only) ------------------------------------------
# Must be the browser-reachable api URL. Locally that's localhost:8000.
# On Railway set it to the api service's public domain.
VITE_API_URL=http://localhost:8000
